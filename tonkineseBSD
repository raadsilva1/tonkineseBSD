#!/usr/local/bin/zsh

export PATH="/usr/local/bin:/usr/X11R6/bin:/bin:/usr/bin:/sbin:/usr/sbin"
umask 022

typeset -g PROJECT="tonkineseBSD"
typeset -g MARKER="# Managed by tonkineseBSD"
typeset -g LOG_FILE="/var/tmp/tonkineseBSD-$(date '+%Y%m%d-%H%M%S').log"
: >"$LOG_FILE" 2>/dev/null || true

typeset -g ZSH_BIN=""
typeset -g TARGET_USER=""
typeset -g TARGET_HOME=""
typeset -g TARGET_GROUP=""
typeset -g TARGET_USER_OVERRIDE=""

typeset -gi SHOW_HELP=0
typeset -gi USE_SNAPSHOT_REPO=0

typeset -g PKG_EMWM_STEM=""
typeset -g PKG_TERMINAL_STEM=""
typeset -g PKG_BROWSER_STEM=""
typeset -g PKG_FILE_MANAGER_STEM=""
typeset -g PKG_IMAGE_STEM=""
typeset -g PKG_PDF_STEM=""
typeset -g PKG_MEDIA_STEM=""
typeset -g PKG_ARCHIVE_STEM=""
typeset -g PKG_CLIPBOARD_STEM=""
typeset -g PKG_XDG_STEM=""
typeset -g PKG_XDG_DIRS_STEM=""
typeset -g PKG_FONTS_STEM=""
typeset -g PKG_FONTSCJK_STEM=""

log_internal() {
    local msg="$*"
    printf '%s %s\n' "$(date '+%Y-%m-%d %H:%M:%S')" "$msg" >> "$LOG_FILE"
}

say() {
    printf '%s\n' "• ${1-}"
}

die() {
    local msg="${1-}"
    log_internal "FATAL $msg"
    printf '%s\n' "$msg" >&2
    exit 1
}

need_cmd() {
    local cmd="${1-}"
    if ! command -v -- "$cmd" >/dev/null 2>&1; then
        die "I could not continue because something essential is missing."
    fi
}

script_path() {
    local self="$0"
    local resolved=""

    if [[ "$self" = /* ]]; then
        print -r -- "$self"
        return 0
    fi

    if [[ "$self" == */* ]]; then
        print -r -- "${self:A}"
        return 0
    fi

    resolved="$(command -v -- "$self" 2>/dev/null)" || true
    if [[ -n "$resolved" ]]; then
        print -r -- "${resolved:A}"
        return 0
    fi

    print -r -- "${PWD:A}/$self"
}

print_usage() {
    local prog="${0:t}"

    cat <<EOF
$PROJECT prepares a default multimedia desktop experience on OpenBSD.

It installs and validates the required desktop pieces for a regular user,
including xenodm, emwm, browser, terminal, file browsing, image/PDF/media
tools, sound service setup, recording permissions, firmware refresh, and the
managed user session files needed to start the desktop cleanly.

Usage:
  $prog [options]

Supported arguments:
  -h, --help
      Show this help text and exit cleanly.

  -S, --snapshot
      Force OpenBSD package commands to use snapshot repository mode for the
      whole script lifecycle. This applies consistently to package searching,
      package resolution, installation checks, and package installation work.

  -u, --user USER
      Use USER as the desktop account target instead of automatic discovery.

      Automatic discovery remains the default when this option is not given.

Invocation notes:
  - This script only works on OpenBSD.
  - Root access is required for system changes.
  - If you run it as a normal user, it will re-run itself through doas.
  - If no target user is specified, the script tries to discover a suitable
    regular desktop user automatically.
  - Progress and command output are written to a log file in /var/tmp.

Examples:
  $prog
      Run the standard setup using automatic user discovery and normal package
      repository behavior.

  $prog --user raad
      Run the setup for the user "raad" instead of auto-detecting the account.

  $prog --snapshot
      Run the setup with snapshot package resolution everywhere the script uses
      OpenBSD package tools.

  $prog --user raad --snapshot
      Run the setup for user "raad" and force snapshot package mode.

  doas $prog --user raad --snapshot
      Run directly as root, with an explicit desktop target and snapshot mode.

  $prog --help
      Show this help screen without making changes.

Usability guidance:
  Run this on the OpenBSD machine you want to prepare.
  Use --user when you want to remove ambiguity and target one specific desktop
  account.
  Use --snapshot only when you intentionally want snapshot package selection for
  all package-management operations performed by this script.
EOF
}

usage_error() {
    local msg="${1-}"

    if [[ -n "$msg" ]]; then
        log_internal "USAGE_ERROR $msg"
        printf '%s\n\n' "$msg" >&2
    fi

    print_usage >&2
    exit 1
}

parse_args() {
    local arg=""
    local value=""

    SHOW_HELP=0
    USE_SNAPSHOT_REPO=0
    TARGET_USER_OVERRIDE=""

    while [[ "$#" -gt 0 ]]; do
        arg="$1"
        case "$arg" in
            -h|--help)
                SHOW_HELP=1
                ;;
            -S|--snapshot|--snapshots)
                USE_SNAPSHOT_REPO=1
                ;;
            -u|--user)
                shift
                if [[ "$#" -eq 0 ]]; then
                    usage_error "The target user option requires a user name."
                fi
                value="$1"
                if [[ -z "$value" ]]; then
                    usage_error "The target user option requires a user name."
                fi
                TARGET_USER_OVERRIDE="$value"
                ;;
            --user=*)
                value="${arg#--user=}"
                if [[ -z "$value" ]]; then
                    usage_error "The target user option requires a user name."
                fi
                TARGET_USER_OVERRIDE="$value"
                ;;
            --)
                shift
                break
                ;;
            -*)
                usage_error "I did not understand the argument: $arg"
                ;;
            *)
                usage_error "This script does not accept positional arguments: $arg"
                ;;
        esac
        shift
    done

    if [[ "$#" -gt 0 ]]; then
        usage_error "This script does not accept extra values: $1"
    fi
}

pkg_add_cmd() {
    if (( USE_SNAPSHOT_REPO )); then
        command pkg_add -D snap "$@"
    else
        command pkg_add "$@"
    fi
}

pkg_info_cmd() {
    if (( USE_SNAPSHOT_REPO )); then
        command pkg_info -D snap "$@"
    else
        command pkg_info "$@"
    fi
}

ensure_root() {
    if [[ "$(id -u)" -eq 0 ]]; then
        return 0
    fi

    need_cmd doas

    local self
    local zsh_bin

    self="$(script_path)"
    zsh_bin="$(command -v -- zsh 2>/dev/null)" || true

    if [[ -z "$zsh_bin" ]]; then
        die "I could not continue because the shell for this setup is missing."
    fi

    say "Getting permission to continue"
    exec doas "$zsh_bin" "$self" "$@"
}

prechecks() {
    if [[ "$(uname -s)" != "OpenBSD" ]]; then
        die "This setup only works on OpenBSD."
    fi

    local cmd
    for cmd in id pkg_add pkg_info rcctl install mv cp chmod chown awk grep head cmp mktemp dirname date who rm sleep stat touch logname fw_update sysctl dmesg cat; do
        need_cmd "$cmd"
    done
}

retry_run() {
    local attempts="${1-}"
    local delay_s="${2-}"
    local friendly="${3-}"
    local -a cmd
    local n=1
    local rc=0

    cmd=("${@[5,-1]}")

    while [[ "$n" -le "$attempts" ]]; do
        log_internal "RUN attempt=$n friendly=$friendly cmd=${(j: :)cmd}"
        if "${cmd[@]}" >> "$LOG_FILE" 2>&1; then
            return 0
        fi

        rc=$?
        log_internal "FAIL attempt=$n rc=$rc friendly=$friendly"

        if [[ "$n" -lt "$attempts" ]]; then
            say "Trying that again"
            sleep "$delay_s"
        else
            return "$rc"
        fi

        n=$(( n + 1 ))
    done
}

backup_file() {
    local path="${1-}"

    if [[ ! -e "$path" ]]; then
        return 0
    fi

    local stamp
    local backup

    stamp="$(date '+%Y%m%d-%H%M%S')"
    backup="$path.tonkineseBSD.bak.$stamp"

    cp -p "$path" "$backup" >> "$LOG_FILE" 2>&1 || die "I stopped to avoid damaging an existing file."

    log_internal "BACKUP $path -> $backup"
}

ensure_dir() {
    local path="${1-}"
    local owner="${2-}"
    local group="${3-}"
    local mode="${4-}"

    if [[ -e "$path" ]]; then
        if [[ ! -d "$path" ]]; then
            die "I stopped because a needed folder is blocked by something else."
        fi

        chown "$owner:$group" "$path" >> "$LOG_FILE" 2>&1 || die "I could not prepare a needed folder."
        chmod "$mode" "$path" >> "$LOG_FILE" 2>&1 || die "I could not prepare a needed folder."
        return 0
    fi

    retry_run 2 1 "Preparing a folder" -- install -d -o "$owner" -g "$group" -m "$mode" "$path" \
        || die "I could not prepare a needed folder."
}

atomic_write_from_stdin() {
    local path="${1-}"
    local owner="${2-}"
    local group="${3-}"
    local mode="${4-}"
    local dir
    local tmp

    dir="$(dirname "$path")"

    if [[ -e "$dir" ]]; then
        if [[ ! -d "$dir" ]]; then
            die "I stopped because a needed folder is blocked by something else."
        fi
    else
        die "I stopped because a needed folder is missing."
    fi

    tmp="$(mktemp "$dir/.tonkineseBSD.XXXXXX")" || die "I could not prepare a safe temporary file."

    if ! cat > "$tmp"; then
        rm -f "$tmp"
        die "I could not prepare a safe file update."
    fi

    if [[ -e "$path" ]]; then
        if cmp -s "$tmp" "$path"; then
            chown "$owner:$group" "$path" >> "$LOG_FILE" 2>&1
            chmod "$mode" "$path" >> "$LOG_FILE" 2>&1
            rm -f "$tmp"
            return 0
        fi

        backup_file "$path"
    fi

    chown "$owner:$group" "$tmp" >> "$LOG_FILE" 2>&1 || {
        rm -f "$tmp"
        die "I could not set file ownership safely."
    }

    chmod "$mode" "$tmp" >> "$LOG_FILE" 2>&1 || {
        rm -f "$tmp"
        die "I could not set file permissions safely."
    }

    mv -f "$tmp" "$path" >> "$LOG_FILE" 2>&1 || {
        rm -f "$tmp"
        die "I could not finish a safe file update."
    }
}

rewrite_key_value_file() {
    local path="${1-}"
    local owner="${2-}"
    local group="${3-}"
    local mode="${4-}"
    local key="${5-}"
    local value="${6-}"
    local dir
    local tmp

    dir="$(dirname "$path")"
    tmp="$(mktemp "$dir/.tonkineseBSD.kv.XXXXXX")" || die "I could not prepare a safe temporary file."

    if [[ -e "$path" ]]; then
        awk -v key="$key" '
            BEGIN {
                pattern = "^[[:space:]]*" key "[[:space:]]*="
            }
            $0 ~ pattern { next }
            { print }
        ' "$path" > "$tmp" || {
            rm -f "$tmp"
            die "I could not prepare a safe file update."
        }
    else
        : > "$tmp" || {
            rm -f "$tmp"
            die "I could not prepare a safe file update."
        }
    fi

    printf '%s\n' "$key=$value" >> "$tmp" || {
        rm -f "$tmp"
        die "I could not prepare a safe file update."
    }

    if [[ -e "$path" ]]; then
        if cmp -s "$tmp" "$path"; then
            chown "$owner:$group" "$path" >> "$LOG_FILE" 2>&1
            chmod "$mode" "$path" >> "$LOG_FILE" 2>&1
            rm -f "$tmp"
            return 0
        fi
        backup_file "$path"
    fi

    chown "$owner:$group" "$tmp" >> "$LOG_FILE" 2>&1 || {
        rm -f "$tmp"
        die "I could not set file ownership safely."
    }

    chmod "$mode" "$tmp" >> "$LOG_FILE" 2>&1 || {
        rm -f "$tmp"
        die "I could not set file permissions safely."
    }

    mv -f "$tmp" "$path" >> "$LOG_FILE" 2>&1 || {
        rm -f "$tmp"
        die "I could not finish a safe file update."
    }
}

is_human_user() {
    local user="${1-}"
    local uid

    if [[ -z "$user" ]]; then
        return 1
    fi

    if ! id "$user" >/dev/null 2>>"$LOG_FILE"; then
        return 1
    fi

    if [[ "$user" == "root" ]]; then
        return 1
    fi

    uid="$(id -u "$user" 2>>"$LOG_FILE")" || return 1
    if [[ "$uid" -lt 1000 ]]; then
        return 1
    fi

    return 0
}

first_console_user() {
    who 2>>"$LOG_FILE" | awk '$2 ~ /^ttyC/ { print $1; exit }'
}

first_regular_user() {
    awk -F: '$3 >= 1000 && $1 != "root" && $1 != "nobody" && $7 !~ /(nologin|false)$/ { print $1; exit }' /etc/passwd
}

determine_target_user() {
    local -a candidates
    local cand

    candidates=(
        "${DOAS_USER-}"
        "${SUDO_USER-}"
        "$(first_console_user)"
        "$(logname 2>/dev/null)"
        "$(first_regular_user)"
    )

    for cand in "${candidates[@]}"; do
        if is_human_user "$cand"; then
            print -r -- "$cand"
            return 0
        fi
    done

    return 1
}

resolve_target_home() {
    local user="${1-}"
    local home=""

    if [[ -r /etc/master.passwd ]]; then
        home="$(awk -F: -v u="$user" '$1 == u { print $9; exit }' /etc/master.passwd)"
    fi

    if [[ -z "$home" && -r /etc/passwd ]]; then
        home="$(awk -F: -v u="$user" '$1 == u { print $6; exit }' /etc/passwd)"
    fi

    print -r -- "$home"
}

resolve_pkg_exact() {
    local stem="${1-}"
    local matches_output=""
    local -a matches
    local match

    matches_output="$(pkg_info_cmd -Q "$stem" 2>>"$LOG_FILE")" || return 1
    matches=("${(@f)matches_output}")

    for match in "${matches[@]}"; do
        if [[ "$match" == "${stem}-"* ]]; then
            print -r -- "$match"
            return 0
        fi
    done

    if [[ "${#matches[@]}" -gt 0 ]]; then
        print -r -- "${matches[1]}"
        return 0
    fi

    return 1
}

ensure_role() {
    local role="${1-}"
    local critical="${2-}"
    local friendly="${3-}"
    local -a candidates
    local stem
    local exact=""

    candidates=("${@:4}")

    for stem in "${candidates[@]}"; do
        if pkg_info_cmd -e "${stem}-*" >/dev/null 2>>"$LOG_FILE"; then
            log_internal "ROLE $role already satisfied by $stem"
            print -r -- "$stem"
            return 0
        fi
    done

    for stem in "${candidates[@]}"; do
        exact="$(resolve_pkg_exact "$stem")" || exact=""
        if [[ -z "$exact" ]]; then
            continue
        fi

        say "$friendly" >&2
        if retry_run 3 3 "$friendly" -- pkg_add_cmd "$exact"; then
            if pkg_info_cmd -e "${stem}-*" >/dev/null 2>>"$LOG_FILE"; then
                log_internal "ROLE $role installed stem=$stem exact=$exact"
                print -r -- "$stem"
                return 0
            fi
            log_internal "ROLE $role verification failed stem=$stem exact=$exact"
        fi
    done

    if [[ "$critical" == "critical" ]]; then
        die "I could not finish installing everything needed."
    fi

    log_internal "ROLE $role optional unavailable or failed"
    return 1
}

ensure_service_ready() {
    local service="${1-}"
    local friendly="${2-}"

    say "$friendly"

    retry_run 2 2 "$friendly" -- rcctl enable "$service" \
        || die "I could not finish a needed background service."

    retry_run 2 2 "$friendly" -- rcctl start "$service" || {
        if ! rcctl check "$service" >/dev/null 2>>"$LOG_FILE"; then
            die "I could not start everything that is needed."
        fi
    }
}

refresh_firmware() {
    say "Checking hardware support"
    retry_run 3 3 "Checking hardware support" -- fw_update \
        || die "I could not finish preparing the machine hardware."
}

apply_runtime_sysctl() {
    local key="${1-}"
    local value="${2-}"

    retry_run 2 1 "Applying a system setting" -- sysctl "$key=$value" \
        || die "I could not apply a needed system setting."
}

ensure_persistent_sysctl() {
    local key="${1-}"
    local value="${2-}"
    rewrite_key_value_file /etc/sysctl.conf root wheel 0644 "$key" "$value"
}

prepare_recording_support() {
    say "Getting sound and camera access ready"
    apply_runtime_sysctl kern.audio.record 1
    apply_runtime_sysctl kern.video.record 1
    ensure_persistent_sysctl kern.audio.record 1
    ensure_persistent_sysctl kern.video.record 1
}

write_managed_xresources() {
    local path="$TARGET_HOME/.config/tonkineseBSD/Xresources"

    {
        printf '%s\n' '! Managed by tonkineseBSD'
        printf '%s\n' 'XTerm*faceName: monospace:size=10'
        printf '%s\n' 'XTerm*utf8: 2'
        printf '%s\n' 'XTerm*saveLines: 5000'
        printf '%s\n' 'XTerm*scrollBar: false'
        printf '%s\n' 'XTerm*background: #101417'
        printf '%s\n' 'XTerm*foreground: #e6e6e6'
        printf '%s\n' 'XTerm*cursorColor: #8fb7ff'
        printf '%s\n' 'XTerm*pointerColorBackground: #101417'
        printf '%s\n' 'XTerm*pointerColorForeground: #e6e6e6'
        printf '%s\n' 'XTerm*metaSendsEscape: true'
        printf '%s\n' 'XTerm*selectToClipboard: true'
    } | atomic_write_from_stdin "$path" "$TARGET_USER" "$TARGET_GROUP" 0644
}

write_managed_xsession() {
    local path="$TARGET_HOME/.xsession"

    {
        printf '%s\n' "#!$ZSH_BIN"
        printf '%s\n' '# Managed by tonkineseBSD'
        printf '%s\n' 'export PATH="/usr/local/bin:/usr/X11R6/bin:/bin:/usr/bin:/sbin:/usr/sbin"'
        printf '%s\n' 'export AUDIODEVICE="snd/default"'
        printf '%s\n' 'umask 022'
        printf '%s\n' 'if [[ -r "$HOME/.config/tonkineseBSD/Xresources" ]]; then'
        printf '%s\n' '    xrdb -merge "$HOME/.config/tonkineseBSD/Xresources" >/dev/null 2>&1'
        printf '%s\n' 'fi'
        printf '%s\n' 'if [[ -r "$HOME/.Xresources.local" ]]; then'
        printf '%s\n' '    xrdb -merge "$HOME/.Xresources.local" >/dev/null 2>&1'
        printf '%s\n' 'fi'
        printf '%s\n' 'if command -v -- xdg-user-dirs-update >/dev/null 2>&1; then'
        printf '%s\n' '    xdg-user-dirs-update >/dev/null 2>&1'
        printf '%s\n' 'fi'
        printf '%s\n' 'if command -v -- xrandr >/dev/null 2>&1; then'
        printf '%s\n' '    xrandr --auto >/dev/null 2>&1'
        printf '%s\n' 'fi'
        printf '%s\n' 'if command -v -- sndioctl >/dev/null 2>&1; then'
        printf '%s\n' '    current_level="$(sndioctl -n output.level 2>/dev/null)"'
        printf '%s\n' '    if [[ -n "$current_level" ]]; then'
        printf '%s\n' '        if [[ "$current_level" =~ ^0(\.0+)?$ ]]; then'
        printf '%s\n' '            sndioctl -q output.level=0.80 >/dev/null 2>&1'
        printf '%s\n' '        fi'
        printf '%s\n' '    fi'
        printf '%s\n' 'fi'
        printf '%s\n' 'xsetroot -solid "#1e232b" >/dev/null 2>&1'
        printf '%s\n' 'exec emwm'
    } | atomic_write_from_stdin "$path" "$TARGET_USER" "$TARGET_GROUP" 0755
}

assert_pkg_installed() {
    local stem="${1-}"

    if [[ -z "$stem" ]]; then
        return 0
    fi

    if ! pkg_info_cmd -e "${stem}-*" >/dev/null 2>>"$LOG_FILE"; then
        die "I stopped because part of the desktop is still missing."
    fi
}

assert_owner() {
    local path="${1-}"
    local expected_user="${2-}"
    local actual_user

    actual_user="$(stat -f %Su "$path" 2>>"$LOG_FILE")" || actual_user=""
    if [[ "$actual_user" != "$expected_user" ]]; then
        die "I stopped because a user file ended up with the wrong ownership."
    fi
}

wait_for_xorg_log() {
    local tries=15

    while [[ "$tries" -gt 0 ]]; do
        if [[ -f /var/log/Xorg.0.log ]]; then
            return 0
        fi
        sleep 1
        tries=$(( tries - 1 ))
    done

    return 1
}

validate_audio_stack() {
    local device=""
    local cand
    local audio_record=""

    for cand in /dev/audioctl0 /dev/audioctl1 /dev/audio0 /dev/audio1; do
        if [[ -c "$cand" ]]; then
            device="$cand"
            break
        fi
    done

    if [[ -z "$device" ]]; then
        die "I stopped because no sound device became available."
    fi

    if [[ "$device" == *audioctl* ]]; then
        if ! audioctl -f "$device" >/dev/null 2>>"$LOG_FILE"; then
            die "I stopped because sound did not become ready."
        fi
    fi

    audio_record="$(sysctl -n kern.audio.record 2>>"$LOG_FILE")" || audio_record=""
    if [[ "$audio_record" != "1" ]]; then
        die "I stopped because microphone access is still blocked."
    fi
}

validate_video_stack() {
    local video_record=""

    if ! wait_for_xorg_log; then
        die "I stopped because the graphics system did not become ready."
    fi

    if grep -Eiq 'no screens found|Fatal server error' /var/log/Xorg.0.log 2>>"$LOG_FILE"; then
        die "I stopped because the graphics system reported a serious problem."
    fi

    video_record="$(sysctl -n kern.video.record 2>>"$LOG_FILE")" || video_record=""
    if [[ "$video_record" != "1" ]]; then
        die "I stopped because camera access is still blocked."
    fi
}

final_validation() {
    local xenodm_status=""
    local sndiod_status=""

    assert_pkg_installed "$PKG_EMWM_STEM"
    assert_pkg_installed "$PKG_BROWSER_STEM"
    assert_pkg_installed "$PKG_FILE_MANAGER_STEM"
    assert_pkg_installed "$PKG_IMAGE_STEM"
    assert_pkg_installed "$PKG_PDF_STEM"
    assert_pkg_installed "$PKG_MEDIA_STEM"
    assert_pkg_installed "$PKG_TERMINAL_STEM"

    if [[ ! -x "$TARGET_HOME/.xsession" ]]; then
        die "I stopped because the desktop start file is not ready."
    fi

    if ! grep -q 'exec emwm' "$TARGET_HOME/.xsession" 2>>"$LOG_FILE"; then
        die "I stopped because the desktop session is not pointing to emwm."
    fi

    if [[ ! -r "$TARGET_HOME/.config/tonkineseBSD/Xresources" ]]; then
        die "I stopped because the desktop defaults are missing."
    fi

    assert_owner "$TARGET_HOME/.xsession" "$TARGET_USER"
    assert_owner "$TARGET_HOME/.config/tonkineseBSD/Xresources" "$TARGET_USER"

    xenodm_status="$(rcctl get xenodm status 2>>"$LOG_FILE")" || xenodm_status=""
    if [[ "$xenodm_status" != "on" ]]; then
        die "I stopped because the login screen is not enabled."
    fi

    if ! rcctl check xenodm >/dev/null 2>>"$LOG_FILE"; then
        die "I stopped because the login screen is not running correctly."
    fi

    sndiod_status="$(rcctl get sndiod status 2>>"$LOG_FILE")" || sndiod_status=""
    if [[ "$sndiod_status" != "on" ]]; then
        die "I stopped because sound is not enabled the way it should be."
    fi

    if ! rcctl check sndiod >/dev/null 2>>"$LOG_FILE"; then
        die "I stopped because sound is not running correctly."
    fi

    validate_audio_stack
    validate_video_stack
}

main() {
    parse_args "$@"

    if (( SHOW_HELP )); then
        print_usage
        return 0
    fi

    prechecks
    ensure_root "$@"
    prechecks

    log_internal "ARGS snapshot=$USE_SNAPSHOT_REPO target_user_override=${TARGET_USER_OVERRIDE:-auto}"

    if (( USE_SNAPSHOT_REPO )); then
        say "Using OpenBSD snapshot repositories for package work"
    fi

    ZSH_BIN="$(command -v -- zsh 2>/dev/null)" || ZSH_BIN=""
    if [[ -z "$ZSH_BIN" ]]; then
        die "I could not continue because the shell for this setup is missing."
    fi

    if [[ -n "$TARGET_USER_OVERRIDE" ]]; then
        if ! is_human_user "$TARGET_USER_OVERRIDE"; then
            die "I could not use the requested desktop user safely."
        fi
        TARGET_USER="$TARGET_USER_OVERRIDE"
    else
        TARGET_USER="$(determine_target_user)" || TARGET_USER=""
        if [[ -z "$TARGET_USER" ]]; then
            die "I could not safely determine which account should receive the desktop setup."
        fi
    fi

    TARGET_HOME="$(resolve_target_home "$TARGET_USER")"
    TARGET_GROUP="$(id -gn "$TARGET_USER")"

    if [[ -z "$TARGET_HOME" ]]; then
        die "I could not safely determine the home folder for the desktop user."
    fi

    if [[ ! -d "$TARGET_HOME" ]]; then
        die "I could not safely determine the home folder for the desktop user."
    fi

    log_internal "TARGET_USER=$TARGET_USER TARGET_HOME=$TARGET_HOME TARGET_GROUP=$TARGET_GROUP"

    PKG_EMWM_STEM="$(ensure_role emwm critical "Installing the main desktop pieces" emwm)"
    PKG_TERMINAL_STEM="$(ensure_role terminal critical "Adding a comfortable terminal" xfce4-terminal)"
    PKG_BROWSER_STEM="$(ensure_role browser critical "Adding a web browser" firefox-esr mozilla-firefox)"
    PKG_FILE_MANAGER_STEM="$(ensure_role files critical "Adding file browsing" thunar pcmanfm-qt)"
    PKG_IMAGE_STEM="$(ensure_role images critical "Adding image viewing" nsxiv feh)"
    PKG_PDF_STEM="$(ensure_role pdf critical "Adding PDF viewing" mupdf xpdf)"
    PKG_MEDIA_STEM="$(ensure_role media critical "Adding media playback" mpv mplayer)"
    PKG_ARCHIVE_STEM="$(ensure_role archive optional "Adding everyday tools" xarchiver)"
    PKG_CLIPBOARD_STEM="$(ensure_role clipboard optional "Adding clipboard support" xclip)"
    PKG_XDG_STEM="$(ensure_role xdg optional "Adding desktop helpers" xdg-utils)"
    PKG_XDG_DIRS_STEM="$(ensure_role xdgdirs optional "Adding home folders" xdg-user-dirs)"
    PKG_FONTS_STEM="$(ensure_role fonts optional "Adding comfortable fonts" noto-fonts)"
    PKG_FONTSCJK_STEM="$(ensure_role fontscjk optional "Adding more fonts" noto-cjk)"

    refresh_firmware
    prepare_recording_support

    ensure_service_ready sndiod "Getting sound ready"
    ensure_service_ready xenodm "Finishing your login screen"

    ensure_dir "$TARGET_HOME/.config" "$TARGET_USER" "$TARGET_GROUP" 0755
    ensure_dir "$TARGET_HOME/.config/tonkineseBSD" "$TARGET_USER" "$TARGET_GROUP" 0755

    local folder
    for folder in Desktop Documents Downloads Music Pictures Videos; do
        ensure_dir "$TARGET_HOME/$folder" "$TARGET_USER" "$TARGET_GROUP" 0755
    done

    say "Making everything start correctly"
    write_managed_xresources
    write_managed_xsession

    say "Cleaning up and checking the result"
    final_validation

    printf '%s\n' ''
    printf '%s\n' 'Your desktop is ready.'
    printf '%s\n' "Log file: $LOG_FILE"
}

main "$@"
